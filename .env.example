# Nexaa AI Editor — API Keys
# Pegar al menos una. Las keys se pueden configurar también desde la UI.
# Después de editar, reiniciar el servidor.

# OpenAI (https://platform.openai.com/api-keys) — de pago, muy barato con gpt-4o-mini
OPENAI_API_KEY=

# Groq (https://console.groq.com/) — FREE TIER, sin tarjeta, signup con email
GROQ_API_KEY=

# Together AI (https://api.together.xyz/) — $5 USD de credito gratis al registrarse, sin tarjeta
TOGETHER_API_KEY=

# Mistral AI (https://console.mistral.ai/) — free tier, sin tarjeta
MISTRAL_API_KEY=

# Brave Search (https://brave.com/search/api/) — 2000 queries/mes free, sin tarjeta
BRAVE_API_KEY=

# Google Gemini (https://aistudio.google.com/app/apikey) — free tier
GEMINI_API_KEY=

# Anthropic Claude (https://console.anthropic.com/) — de pago
CLAUDE_API_KEY=
